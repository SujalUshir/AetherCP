{
  "manifest_version": 3,
  "name": "AetherCP",
  "version": "1.0",
  "description": "Competitive Programming Tracker",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://codeforces.com/*",
    "https://leetcode.com/*"
  ],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://codeforces.com/*",
        "https://leetcode.com/*"
      ],
      "js": [
        "src/shared/constants.js",
        "src/content/content.js"
      ]
    },
    {
      "matches": [
        "https://codeforces.com/profile/*"
      ],
      "js": [
        "src/vendor/chart.umd.min.js",
        "src/shared/constants.js",
        "src/utils/time.js",
        "src/platform/codeforces/graphTemplates.js",
        "src/platform/codeforces/profileAnalytics.js",
        "src/platform/codeforces/profileSections.js",
        "src/platform/codeforces/profileCharts.js",
        "src/platform/codeforces/profileInjector.js"
      ],
      "css": [
        "src/platform/codeforces/profileAnalytics.css"
      ]
    }
  ]
}
