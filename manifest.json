{
  "manifest_version": 3,
  "name": "AetherCP",
  "version": "1.0",
  "description": "Competitive Programming Tracker",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://codeforces.com/*",
    "https://leetcode.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://codeforces.com/*",
        "https://leetcode.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}